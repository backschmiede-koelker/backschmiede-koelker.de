generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum OfferKind {
  RECURRING_WEEKDAY
  ONE_DAY
  DATE_RANGE
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Location {
  RECKE
  METTINGEN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  priceCents Int
  unit       String   // z.B. "pro Stück", "kg", "100g"
  imageUrl   String?
  tags       String[] // Postgres text[]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  offers     Offer[]  @relation("ProductOffers")

  @@index([isActive, createdAt])     // Listenansichten „nur aktive, neueste zuerst“
  @@index([name])                    // einfache Textsuche (LIKE/ILIKE)
}

model Offer {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?
  priceCents  Int?
  unit        String?
  imageUrl    String?
  tags        String[]
  isActive    Boolean   @default(true)
  
  // Gültigkeit
  kind        OfferKind
  weekday     Weekday?   // nur für RECURRING_WEEKDAY
  date        DateTime?  // nur für ONE_DAY (ganzer Tag)
  startDate   DateTime?  // nur für DATE_RANGE
  endDate     DateTime?  // nur für DATE_RANGE

  locations   Location[]
  priority    Int        @default(0)

  productId   String?
  product     Product?   @relation("ProductOffers", fields: [productId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, kind])
  @@index([date])
  @@index([weekday])
  @@index([startDate, endDate])
  @@index([priority, createdAt]) 
}

// Optional: zentrale Textbausteine (falls du *nicht* inline auf der Seite editierst)
model ContentBlock {
  id        String   @id @default(cuid())
  slug      String   @unique // z.B. "startseite.hero"
  content   String   // Markdown/HTML/Plain
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
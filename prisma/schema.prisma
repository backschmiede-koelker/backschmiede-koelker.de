// /prisma/shema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum OfferKind {
  RECURRING_WEEKDAY
  ONE_DAY
  DATE_RANGE
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum Location {
  RECKE
  METTINGEN
}

enum OfferProductRole {
  QUALIFIER           // Muss gekauft werden, um das Angebot auszulösen
  REWARD_FREE         // Gratis-Position (Stückzahl > 0, Preis = 0)
  REWARD_DISCOUNTED   // Vergünstigte Position (perItemPriceCents festgelegt)
  BUNDLE_COMPONENT    // Bestandteil eines Sets mit Gesamtpreis (Offer.priceCents)
  CHOICE_QUALIFIER    // Qualifizierer: „eins/mehrere zur Wahl“ (aus einer Liste)
  CHOICE_REWARD       // Belohnung: „eins/mehrere zur Wahl“ (aus einer Liste)
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  priceCents Int
  unit       String   // z.B. "pro Stück", "kg", "100g"
  imageUrl   String?
  tags       String[] // Postgres text[]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  offerLinks OfferProduct[]

  @@index([isActive, createdAt])     // Listenansichten „nur aktive, neueste zuerst“
  @@index([name])                    // einfache Textsuche (LIKE/ILIKE)
}

model Offer {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?
  priceCents  Int?
  originalPriceCents Int?  
  unit        String?
  imageUrl    String?
  tags        String[]
  isActive    Boolean   @default(true)
  
  // Gültigkeit
  kind        OfferKind
  weekday     Weekday?   // nur für RECURRING_WEEKDAY
  date        DateTime?  // nur für ONE_DAY (ganzer Tag)
  startDate   DateTime?  // nur für DATE_RANGE
  endDate     DateTime?  // nur für DATE_RANGE

  locations   Location[]
  priority    Int        @default(0)

  products    OfferProduct[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, kind])
  @@index([date])
  @@index([weekday])
  @@index([startDate, endDate])
  @@index([priority, createdAt]) 
}

model OfferProduct {
  offerId   String
  productId String
  role      OfferProductRole
  quantity  Int                 @default(1)
  perItemPriceCents Int?

  offer   Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@id([offerId, productId, role])
}

// Optional: zentrale Textbausteine (falls du *nicht* inline auf der Seite editierst)
model ContentBlock {
  id        String   @id @default(cuid())
  slug      String   @unique // z.B. "startseite.hero"
  content   String   // Markdown/HTML/Plain
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Pageview {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  path         String
  referrerHost String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?

  lang         String?  // z.B. "de"
  device       String?  // "desktop" | "mobile" | "tablet"
  browser      String?  // z.B. "Chrome 126" | "Safari"
  country      String?  // ISO-CC, z.B. "DE"

  sessionId    String?  // kurzlebige, anonyme Session-ID (Cookie)
  ipHash       String?  // tagesbasierter Hash (ohne echte IP)
  isBot        Boolean  @default(false)
  isAdmin      Boolean  @default(false)

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([referrerHost])
  @@index([utmSource, utmMedium, utmCampaign])
  @@index([device])
  @@index([browser])
  @@index([lang])
}
